{
  "version": 2,
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 8 * * *"
    }
  ],
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/api/db", "dest": "/api/db.js" },
    { "src": "/api/sync", "dest": "/api/sync.js" },
    { "src": "/", "dest": "/index.html" }
  ]
}
